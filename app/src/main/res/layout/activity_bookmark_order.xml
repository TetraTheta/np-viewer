<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bookmark_order_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

  <LinearLayout
      android:id="@+id/bookmark_order_toolbar"
      android:layout_width="match_parent"
      android:layout_height="56dp"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingHorizontal="4dp">

    <ImageButton
        android:id="@+id/bookmark_order_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/tooltip_back"
        android:padding="12dp"
        app:srcCompat="@drawable/ic_arrow_back_24" />

    <TextView
        android:id="@+id/bookmark_order_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/title_activity_bookmark_order"
        android:textAppearance="?attr/textAppearanceTitleLarge" />
  </LinearLayout>

  <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/bookmark_order_list"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:clipToPadding="false"
      android:paddingVertical="4dp"
      app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
</LinearLayout>
